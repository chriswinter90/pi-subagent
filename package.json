{
  "name": "@agwab/pi-subagent",
  "version": "0.4.5",
  "description": "Minimal subagent runtime for Pi.",
  "type": "module",
  "private": false,
  "keywords": [
    "pi-package",
    "pi",
    "subagent",
    "agent",
    "sandbox"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./src/index.ts",
    "./api": {
      "types": "./src/api.ts",
      "default": "./api.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "api.mjs",
    "src",
    "docs",
    "assets",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "image": "https://raw.githubusercontent.com/AgwaB/pi-subagent/main/assets/subagent-panel.png"
  },
  "scripts": {
    "check:scripts": "for d in scripts test; do [ -d \"$d\" ] && find \"$d\" -name '*.mjs' -print; done | xargs -n1 node --check",
    "check:resolver": "node ./test/checks/resolver.mjs",
    "check:api": "node ./test/checks/api.mjs",
    "check:artifacts": "node ./test/checks/artifacts.mjs",
    "check:parent-session": "node ./test/checks/parent-session.mjs",
    "check:panel-session-scope": "node ./test/checks/panel-session-scope.mjs",
    "check:contracts": "node ./test/checks/contracts.mjs",
    "check:agents": "node ./test/checks/agents.mjs",
    "check:no-chain": "node ./test/checks/no-chain.mjs",
    "check:panel": "node ./test/checks/panel.mjs",
    "check:worktree-cleanup": "node ./test/checks/worktree-cleanup.mjs",
    "check:workspace-policy": "node ./test/checks/workspace-policy.mjs",
    "check:lifecycle": "node ./test/checks/lifecycle.mjs",
    "check:fail-fast": "node ./test/checks/fail-fast.mjs",
    "check:schema-sync": "node ./test/checks/schema-sync.mjs",
    "check:run-lock": "node ./test/checks/run-lock.mjs",
    "check:reconcile": "node ./test/checks/reconcile.mjs",
    "check:headless-streaming": "node ./test/checks/headless-streaming.mjs",
    "check:model:inline": "node ./test/integration/inline-model.mjs",
    "check:model:headless": "node ./test/integration/headless-model.mjs",
    "check:model:tmux": "node ./test/integration/tmux-model.mjs",
    "check:all": "npm run check:static && npm run check:integration",
    "validate": "npm run check:scripts && npm run check:static",
    "release:check": "node ./scripts/release-check.mjs",
    "check": "npm run check:static",
    "check:types": "tsc -p tsconfig.json",
    "check:static": "npm run check:types && npm run check:api && npm run check:resolver && npm run check:artifacts && npm run check:parent-session && npm run check:panel-session-scope && npm run check:contracts && npm run check:agents && npm run check:no-chain && npm run check:panel && npm run check:worktree-cleanup && npm run check:workspace-policy && npm run check:lifecycle && npm run check:fail-fast && npm run check:schema-sync && npm run check:run-lock && npm run check:reconcile && npm run check:headless-streaming",
    "check:integration": "npm run check:model:inline && npm run check:model:headless && npm run check:model:tmux"
  },
  "dependencies": {
    "@anthropic-ai/sandbox-runtime": "^0.0.54",
    "jiti": "^2.7.0",
    "typebox": "^1.2.3"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@types/node": "^24.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": false
    },
    "@earendil-works/pi-coding-agent": {
      "optional": false
    },
    "@earendil-works/pi-tui": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgwaB/pi-subagent.git"
  },
  "homepage": "https://github.com/AgwaB/pi-subagent#readme",
  "bugs": {
    "url": "https://github.com/AgwaB/pi-subagent/issues"
  }
}
